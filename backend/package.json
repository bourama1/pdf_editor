{
    "name": "pdf-editor-backend",
    "version": "1.0.0",
    "description": "PDF Editor – standalone server",
    "main": "dist/server.js",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only server.ts",
        "build:frontend": "cd ../frontend && npx vite build",
        "build": "npx tsc",
        "package": "node node_modules/@yao-pkg/pkg/lib-es5/bin.js dist/server.js --output pdf-editor.exe"
    },
    "pkg": {
        "assets": [
            "public/**/*"
        ],
        "targets": [
            "node24-win-x64"
        ]
    },
    "dependencies": {
        "cors": "^2.8.5",
        "express": "^4.19.2",
        "multer": "^2.2.0",
        "socket.io": "^4.7.5"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/multer": "^1.4.11",
        "@yao-pkg/pkg": "^6.20.0",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.4.5"
    }
}
